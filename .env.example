# =============================================================
#  SaarthiX — Environment Variables Template
#  Copy this file to .env (never commit the real .env!)
#  In Vercel: set these under Project Settings → Environment Variables
# =============================================================

# ─── Server Config ────────────────────────────────────────────
PORT=3000
POLL_INTERVAL_MS=7000

# ─── Twelve Data API (Free tier: 800 req/day, supports .NS suffix for NSE) ──
# Get a free key at: https://twelvedata.com
TWELVEDATA_API_KEY=

# ─── Finnhub API (Free tier: 60 req/min, market news & sentiment) ───────────
# Get a free key at: https://finnhub.io
FINNHUB_API_KEY=

# ─── Financial News API (Free tier: 100 req/day for headlines & events) ─────
# Get a free key at: https://www.marketaux.com OR https://newsapi.org
NEWS_API_KEY=

# ─── Anthropic API (For Claude LLM market thesis generation) ───────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Gemini API (Free tier: 15 RPM / 1500 RPD for AI thesis generation) ────
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=

# ─── Groww Trade API (REQUIRED for live Indian stock prices) ───────────────
# Profile → Settings → Trade APIs in the Groww Mobile App
GROWW_API_KEY=
GROWW_API_SECRET=

# ─── ATB Stock Analysis API (Deep AI Analysis fallback) ────────────────────
# Get your key at: https://api.atb.money
ATB_API_KEY=

# ─── Dhan Developer Credentials (Optional legacy fallback) ──────────────────
DHAN_API_KEY=
DHAN_API_SECRET=
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

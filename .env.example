# =============================================================
#  SaarthiX — Environment Variables
#  Copy this file to .env (never commit the real .env!)
#  In Vercel: set these under Project Settings → Environment Variables
# =============================================================

# ─── Groww Trade API (REQUIRED for live market data) ──────────
#
# HOW TO GET YOUR GROWW API CREDENTIALS:
#   1. Open the Groww app on your phone
#   2. Go to: Profile → Settings → Trade APIs
#   3. Enable API access and generate an API Key + API Secret
#   4. GROWW_API_KEY  = the "API Key" shown (a long alphanumeric string)
#   5. GROWW_API_SECRET = the "API Secret" / TOTP Secret (the base-32 string
#      you scan into an authenticator app — e.g. Google Authenticator)
#
# NOTE: The server uses TOTP to automatically generate 6-digit OTPs and
# exchange them for a short-lived Access Token. You never need to generate
# the OTP manually; the backend handles it on every startup/expiry.
#
GROWW_API_KEY=
GROWW_API_SECRET=

# ─── Dhan Developer credentials (optional — legacy fallback) ──
DHAN_API_KEY=
DHAN_API_SECRET=
DHAN_ACCESS_TOKEN=
DHAN_CLIENT_ID=

# ─── Server Config ────────────────────────────────────────────
PORT=3000
POLL_INTERVAL_MS=7000

# ─── Finnhub (optional — for global filings & transcripts) ────
FINNHUB_API_KEY=

# ─── RapidAPI (optional — for Indian Share Market News feed) ──
RAPIDAPI_KEY=

# ─── ATB Stock Analysis API (stock-thesis, earnings, valuation, bear-vs-bull, insider-signal) ──
# Get your key at https://api.atb.money
ATB_API_KEY=
